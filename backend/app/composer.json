{
  "name": "docker-template/app",
  "type": "project",
  "require": {
    "php-di/php-di": "^7.1",
    "firebase/php-jwt": "^7.0",
    "nikic/fast-route": "^1.3",
    "robmorgan/phinx": "^0.16.11"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,

  "scripts": {
    "phinx": "vendor/bin/phinx -c phinx.php"
  }
}
